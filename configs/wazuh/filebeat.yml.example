# =============================================================
# Filebeat Configuration — Wazuh SIEM Pipeline
# =============================================================
# Routes alerts from Wazuh Manager to the Wazuh Indexer.
#
# This was the source of a significant troubleshooting effort:
# the dashboard showed zero alerts because keystore credentials
# were missing and index routing was misconfigured.
#
# See docs/full-lab-writeup.pdf for the full story.
# =============================================================

# --- Input: Wazuh alerts ---
filebeat.modules:
  - module: wazuh
    alerts:
      enabled: true
    archives:
      enabled: false

# --- Output: Wazuh Indexer ---
output.elasticsearch:
  hosts:
    - "https://WAZUH_INDEXER_IP:9200"

  # Credentials are stored in the Filebeat keystore, NOT here.
  # Set them with:
  #   filebeat keystore add username
  #   filebeat keystore add password
  username: "${username}"
  password: "${password}"

  # SSL — required for Wazuh Indexer
  ssl.certificate_authorities:
    - /etc/filebeat/certs/root-ca.pem
  ssl.certificate: /etc/filebeat/certs/filebeat.pem
  ssl.key: /etc/filebeat/certs/filebeat-key.pem

  # Index routing — must match Wazuh Indexer's expected format
  index: "wazuh-alerts-4.x-%{+yyyy.MM.dd}"

# --- Template settings ---
setup.template.name: "wazuh"
setup.template.pattern: "wazuh-alerts-4.x-*"
setup.template.overwrite: true
setup.template.enabled: true

setup.ilm.enabled: false

# --- Logging ---
logging.level: info
logging.to_files: true
logging.files:
  path: /var/log/filebeat
  name: filebeat.log
  keepfiles: 7
  permissions: 0644
